# ── Mode ──────────────────────────────────────────────────────────────────────
USE_MOCK=true       # Set false for live AWS

# ── AWS (only needed when USE_MOCK=false) ──────────────────────────────────────
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_REGION=ap-south-1

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+16164044183
TWILIO_WHATSAPP_FROM=whatsapp:+16164044183  # Twilio sandbox default

# ── Contacts ──────────────────────────────────────────────────────────────────
OWNER_PHONE=+918605606859
OWNER_WHATSAPP=whatsapp:+918605606859
ML_PHONE=+918605606859
ML_WHATSAPP=whatsapp:+918605606859
ONCALL_PHONE=+918605606859
ONCALL_WHATSAPP=whatsapp:+918605606859

# ── Approval server ───────────────────────────────────────────────────────────
# If using ngrok to expose locally for Twilio webhooks:
# APPROVAL_BASE_URL=https://your-ngrok-url.ngrok.io
APPROVAL_BASE_URL=http://localhost:5050
